# Ignore everything by default
/*

# Track our .gitignore and workspace settings
!.gitignore
!*.code-workspace

# Track our custom security plugin only
!wp-content/
wp-content/*
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/wp-security-hardening/

# Development and IDE Files
.idea/
.vscode/
.scannerwork/
.sonarlint/
.sonar/
.phpintel/
.php_cs.cache
.php-cs-fixer.cache
.phpunit.result.cache
.phpstan.neon
.phpcs.xml
.phpcs.xml.dist
.phplint.cache
.phplint-cache
.php_cs
.php_cs.dist
.php-cs-fixer.php
.php-cs-fixer.dist.php

# Hidden Files and Directories
# Removed .* to allow workspace file
.*

# Node modules and build files
node_modules/
dist/
build/
*.min.css
*.min.js

# Composer
vendor/
composer.phar

# Testing
phpunit.xml
coverage/
tests/_output/
.phpunit.result.cache

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs and databases
*.log
*.sql
*.sqlite
